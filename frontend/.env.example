# Файл для Vite: положите копию как frontend/.env.local (обязательно префикс VITE_).
# Корневой .env без VITE_ не попадёт в сборку фронтенда.

VITE_SUPABASE_URL=https://xxxx.supabase.co
# Допустимые альтернативы имени переменной (любая пара URL + ключ):
# VITE_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co

VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx
# или VITE_SUPABASE_ANON_KEY=eyJ...  или VITE_PUBLIC_SUPABASE_ANON_KEY=...

# Колонка текста в task_chat_messages (как в БД с мобильным приложением). По умолчанию: body.
# VITE_TASK_CHAT_MESSAGE_COLUMN=body

# Bucket для вложений чата (как в Supabase Storage). По умолчанию: task-chat-media
# VITE_TASK_CHAT_MEDIA_BUCKET=task-chat-media

# Создание обходчиков через FastAPI. В dev можно оставить пустым — см. proxy в vite.config.ts.
# VITE_API_BASE_URL=http://127.0.0.1:8000
