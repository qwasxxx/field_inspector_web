# Скопируйте в backend/.env и подставьте значения. Файл .env в git не коммитится (см. backend/.gitignore).
# Запуск: из каталога backend/ — uvicorn app.main:app --reload --host 127.0.0.1 --port 8000
DATABASE_URL=sqlite+aiosqlite:///./field_inspector.db
# Добавьте сюда фактический порт Vite (5173/5174 и т.д.), если в браузере открываете не тот же origin.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# Создание обходчиков (auth.users + public.profiles) — только на сервере.
# ANON_KEY: обычно тот же publishable/anon ключ, что и VITE_SUPABASE_PUBLISHABLE_KEY на фронте.
# SERVICE_ROLE_KEY: только из Dashboard → API → service_role (не коммитить).
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=замените_на_service_role_из_Supabase_Dashboard

# Срочные уведомления в Telegram (после настройки Database Webhook в Supabase → этот URL).
# URL вебхука: https://<ваш-хост>/api/v1/webhooks/supabase-db
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=
# Опционально: тот же секрет в заголовке X-Webhook-Secret в настройках вебхука Supabase.
TELEGRAM_WEBHOOK_SECRET=
# true — уведомлять и о заявках inspection_task_requests с priority=medium
TELEGRAM_NOTIFY_TASK_REQUEST_MEDIUM=false
