# Пример для backend/.env (не коммитить секреты)
DATABASE_URL=sqlite+aiosqlite:///./field_inspector.db
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Создание обходчиков (auth.users + public.profiles) — только на сервере.
# ANON_KEY: обычно тот же publishable/anon ключ, что и VITE_SUPABASE_PUBLISHABLE_KEY на фронте.
# SERVICE_ROLE_KEY: только из Dashboard → API → service_role (не коммитить).
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=замените_на_service_role_из_Supabase_Dashboard
